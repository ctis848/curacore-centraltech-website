generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String
  role          Role       @default(CLIENT)

  tenantId      String?
  tenant        Tenant?    @relation(fields: [tenantId], references: [id])

  createdAt     DateTime   @default(now())

  accounts                Account[]
  emailVerificationTokens EmailVerificationToken[]
  licenses                License[]
  licenseRequests         LicenseRequest[]
  passwordResetTokens     PasswordResetToken[]
  sessions                Session[]
  teams                   Team[]          @relation("OwnedTeams")
  teamMemberships         TeamMember[]
  invoices                Invoice[]
  supportTickets          SupportTicket[]
  ticketReplies           TicketReply[]
  notifications           Notification[]
  auditLogs               AuditLog[]      @relation("UserAuditLogs")
  exportHistory           ExportHistory[]
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model License {
  id                 String        @id @default(uuid())
  userId             String
  licenseRequestId   String?       @unique
  productName        String?
  licenseKey         String?       @unique

  // Purchase & activation tracking
  purchasedAt        DateTime?     // ⭐ Added to match seed.ts
  activatedAt        DateTime?
  activationCount    Int           @default(0)
  maxActivations     Int?

  // Expiration
  expiresAt          DateTime?

  // Annual fee logic
  annualFeePercent   Int           @default(20)
  annualFeePaidUntil DateTime?

  // Status
  status             LicenseStatus @default(PENDING)

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  licenseRequest     LicenseRequest?      @relation(fields: [licenseRequestId], references: [id])
  user               User                 @relation(fields: [userId], references: [id])
  licenseHistory     LicenseHistory[]
  machineActivations MachineActivation[]
  validationLogs     LicenseValidationLog[]
  invoices           Invoice[]
  supportTickets     SupportTicket[]

  @@index([status])
  @@index([userId])
}

model LicenseValidationLog {
  id         String   @id @default(uuid())
  licenseId  String?
  deviceId   String?
  ipAddress  String?
  appVersion String?
  os         String?
  result     String
  createdAt  DateTime @default(now())

  license License? @relation(fields: [licenseId], references: [id])

  @@index([licenseId])
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  admin User @relation("UserAuditLogs", fields: [adminId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  message   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  user User? @relation(fields: [userId], references: [id])
}

model LicenseHistory {
  id        String   @id @default(uuid())
  licenseId String
  action    String
  details   String?
  createdAt DateTime @default(now())

  license License @relation(fields: [licenseId], references: [id])

  @@index([licenseId])
}

model LicenseRequest {
  id          String        @id @default(uuid())
  userId      String
  requestKey  String
  productName String?
  notes       String?
  status      LicenseStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  processedAt DateTime?
  processedBy String?

  license License?
  user    User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model MachineActivation {
  id          String   @id @default(uuid())
  licenseId   String
  machineId   String
  machineName String?
  osVersion   String?
  ipAddress   String?
  activatedAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  license License @relation(fields: [licenseId], references: [id])

  @@unique([licenseId, machineId])
  @@index([licenseId])
}

model Team {
  id        String   @id @default(uuid())
  ownerId   String
  name      String
  createdAt DateTime @default(now())

  owner   User         @relation("OwnedTeams", fields: [ownerId], references: [id])
  members TeamMember[]

  @@index([ownerId])
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model PasswordResetToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Invoice {
  id          String        @id @default(uuid())
  userId      String
  licenseId   String?
  amount      Float
  currency    String        @default("USD")
  status      InvoiceStatus @default(PENDING)
  transactionId String? @db.VarChar(255)
  createdAt   DateTime      @default(now())
  paidAt      DateTime?
  description String?

  user    User     @relation(fields: [userId], references: [id])
  license License? @relation(fields: [licenseId], references: [id])

  @@index([userId])
  @@index([licenseId])
}

model SupportTicket {
  id        String       @id @default(uuid())
  userId    String
  licenseId String?
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  license License? @relation(fields: [licenseId], references: [id])
  replies TicketReply[]   // ⭐ add this

  @@index([userId])
  @@index([licenseId])
}

model TicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String?
  message   String
  fromAdmin Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id])
  user   User?         @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@index([userId])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model QuoteRequest {
  id           String   @id @default(uuid())
  name         String
  email        String
  organization String?
  details      String
  createdAt    DateTime @default(now())
}

model ApiLog {
  id         String   @id @default(uuid())
  endpoint   String
  statusCode Int
  createdAt  DateTime @default(now())
}

model ExportHistory {
  id        String   @id @default(uuid())
  userId    String?
  fileName  String?
  dataset   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())

  users     User[]
}

model Theme {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Role {
  CLIENT
  ADMIN
  SUPERADMIN
}

enum LicenseStatus {
  PENDING
  APPROVED
  ACTIVE
  EXPIRED
  DEACTIVATED
  INACTIVE
  REVOKED
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
